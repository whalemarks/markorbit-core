ctedObjectType: EVIDENCE_OBJECT_TYPE,
+    expectedDomain: EVIDENCE_DOMAIN
+  });
+  return resolved.ok
+    ? resolved
+    : safe('InvalidEvidenceReference', 'Evidence reference is invalid.');
+}
